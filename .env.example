# ============ API 密钥 ============
# 硅基流动 API Key（文章生成 + AI生图）
SILICONFLOW_API_KEY=

# 图库搜索 API（免费，stock模式需要）
PEXELS_API_KEY=
PIXABAY_API_KEY=

# SM.MS 图床 Token（图片在线化）
SMMS_TOKEN=

# ============ 可选配置 ============
# 图片来源模式：stock / ai / auto
IMAGE_SOURCE=stock

# AI模型（默认Qwen3-235B，硅基流动平台）
MODEL_NAME=Qwen/Qwen3-235B-A22B-Instruct-2507

# ============ 数据持久化（云部署用）============
# GitHub 仓库地址（用于存储生成的文章数据）
# DATA_GIT_REPO=https://github.com/你的用户名/wxarticle
# GitHub Personal Access Token（需要 repo 权限）
# DATA_GIT_TOKEN=ghp_xxxxxxxxxxxxx
# 存储分支（默认 data）
# DATA_GIT_BRANCH=data
